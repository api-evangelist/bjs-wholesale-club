{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/bjs-wholesale-club/main/json-schema/bjs-product-schema.json",
  "title": "BJS Product",
  "description": "Schema for a BJ's Wholesale Club product record",
  "type": "object",
  "properties": {
    "productId": {
      "type": "string",
      "description": "Unique product identifier"
    },
    "name": {
      "type": "string",
      "description": "Product display name"
    },
    "description": {
      "type": "string",
      "description": "Full product description"
    },
    "brand": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "subcategory": {
      "type": "string"
    },
    "price": {
      "type": "number",
      "description": "Member price in USD"
    },
    "regularPrice": {
      "type": "number",
      "description": "Regular retail price in USD"
    },
    "unit": {
      "type": "string",
      "description": "Unit of measure"
    },
    "images": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uri"
      }
    },
    "memberExclusive": {
      "type": "boolean"
    },
    "inStock": {
      "type": "boolean"
    }
  },
  "required": ["productId", "name", "price"]
}
